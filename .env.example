SLACK_SIGNING_SECRET=
PORT=3339
KKOMA_ENGINE_MODE=self_hosted
KKOMA_DATA_DIR=./data
KKOMA_STATE_DB=./data/game_state.db
KKOMA_PUBLIC_RESPONSES=1

# /sema (영어 Semantle) — 기본 on. legacy.semantle.com 사용.
# KKOMA_ENABLE_SEMA=1
# KKOMA_SEMA_REMOTE_BASE_URL=https://legacy.semantle.com
# KKOMA_EN_DATA_DIR=./data/en

# Fast smoke test only. This calls the public 꼬맨틀 server instead of local data.
# KKOMA_ENGINE_MODE=remote
# KKOMA_REMOTE_BASE_URL=https://semantle-ko.newsjel.ly

# Lets the local engine return scores without top-1000 rank data.
# Use only for debugging; exact 꼬맨틀 behavior needs valid_nearest.dat.
# KKOMA_ALLOW_SCORE_ONLY=1
